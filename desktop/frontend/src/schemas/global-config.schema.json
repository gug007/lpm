{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LPM Global Config",
  "description": "Actions and terminals available in every project.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "extends": {
      "type": "array",
      "description": "Templates to layer underneath the global config. Refs are bare names (resolved from ~/.lpm/templates/<name>.yml), absolute paths, or paths relative to ~/.lpm/.",
      "items": { "type": "string" }
    },
    "actions": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/action" }
        },
        {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/definitions/action" },
              {
                "type": "object",
                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            ]
          }
        }
      ]
    },
    "terminals": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/terminal" }
        },
        {
          "type": "array",
          "items": {
            "allOf": [
              { "$ref": "#/definitions/terminal" },
              {
                "type": "object",
                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            ]
          }
        }
      ]
    }
  },
  "definitions": {
    "envMap": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "action": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "description": "Key used when the action is defined in array form." },
            "cmd": { "type": "string" },
            "label": { "type": "string" },
            "emoji": { "type": "string", "description": "Optional emoji shown as the action's icon and on the terminal tab it launches." },
            "shortcut": { "type": "string", "description": "Optional keyboard shortcut that runs the action while the project is open, e.g. \"cmd+shift+b\". Must include cmd or alt." },
            "cwd": { "type": "string" },
            "port": {
              "oneOf": [
                { "type": "integer", "minimum": 0, "maximum": 65535 },
                { "type": "string", "pattern": "^\\s*\\d{1,5}\\s*(-\\s*\\d{1,5}\\s*)?$" },
                {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "integer", "minimum": 0, "maximum": 65535 },
                      { "type": "string", "pattern": "^\\s*\\d{1,5}\\s*(-\\s*\\d{1,5}\\s*)?$" }
                    ]
                  }
                }
              ],
              "description": "Port(s) the action wants free before it runs. Accepts a single port, an inclusive range string like \"3002-3010\", or a list mixing both. Busy ports are handled per \"portConflict\"."
            },
            "portConflict": {
              "type": "string",
              "enum": ["ask", "free", "fail"],
              "default": "ask",
              "description": "What to do when a declared port is busy. \"ask\" (default) prompts before freeing it; \"free\" frees it automatically; \"fail\" refuses to run."
            },
            "env": { "$ref": "#/definitions/envMap" },
            "confirm": { "type": "boolean" },
            "display": {
              "anyOf": [
                { "type": "string", "enum": ["header", "footer"] },
                { "type": "string", "pattern": "^menu$" }
              ],
              "default": "header",
              "description": "Where the action appears. Defaults to \"header\" when omitted. \"menu\" is still accepted but no longer suggested.",
              "errorMessage": "Invalid \"display\" value. Use \"header\" or \"footer\" (\"button\" → use \"header\")."
            },
            "type": { "type": "string" },
            "reuse": { "type": "boolean" },
            "position": {
              "type": "number",
              "description": "Optional sort key. Lower values render first; entries without a position fall back to alphabetical order. Floats are allowed so items can be inserted between existing positions without renumbering."
            },
            "inputs": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/actionInput" }
            },
            "actions": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/action" }
            }
          }
        }
      ]
    },
    "actionInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean" },
        "placeholder": { "type": "string" },
        "default": { "type": "string" },
        "options": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["label", "value"],
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string" },
                  "value": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    },
    "terminal": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "description": "Key used when the terminal is defined in array form." },
            "cmd": { "type": "string" },
            "label": { "type": "string" },
            "emoji": { "type": "string", "description": "Optional emoji shown as the terminal tab's icon." },
            "cwd": { "type": "string" },
            "port": {
              "oneOf": [
                { "type": "integer", "minimum": 0, "maximum": 65535 },
                { "type": "string", "pattern": "^\\s*\\d{1,5}\\s*(-\\s*\\d{1,5}\\s*)?$" },
                {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      { "type": "integer", "minimum": 0, "maximum": 65535 },
                      { "type": "string", "pattern": "^\\s*\\d{1,5}\\s*(-\\s*\\d{1,5}\\s*)?$" }
                    ]
                  }
                }
              ],
              "description": "Port(s) the terminal wants free before it launches. Accepts a single port, an inclusive range string like \"3002-3010\", or a list mixing both. Busy ports are handled per \"portConflict\"."
            },
            "portConflict": {
              "type": "string",
              "enum": ["ask", "free", "fail"],
              "default": "ask",
              "description": "What to do when a declared port is busy. \"ask\" (default) prompts before freeing it; \"free\" frees it automatically; \"fail\" refuses to launch."
            },
            "env": { "$ref": "#/definitions/envMap" },
            "confirm": { "type": "boolean" },
            "reuse": { "type": "boolean" },
            "display": {
              "anyOf": [
                { "type": "string", "enum": ["header", "footer"] },
                { "type": "string", "pattern": "^menu$" }
              ],
              "default": "header",
              "description": "Where the action appears. Defaults to \"header\" when omitted. \"menu\" is still accepted but no longer suggested.",
              "errorMessage": "Invalid \"display\" value. Use \"header\" or \"footer\" (\"button\" → use \"header\")."
            },
            "position": {
              "type": "number",
              "description": "Optional sort key. Lower values render first; entries without a position fall back to alphabetical order."
            },
            "inputs": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/actionInput" }
            },
            "actions": {
              "type": "object",
              "additionalProperties": { "$ref": "#/definitions/action" }
            }
          }
        }
      ]
    }
  }
}
